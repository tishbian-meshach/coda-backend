# CODA Backend Configuration

# Groq API Keys (get from https://console.groq.com/)
# Add multiple keys for fallback
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_2=
GROQ_API_KEY_3=

# Groq Models (comma-separated, tried in order)
GROQ_MODELS=llama-3.3-70b-versatile,llama-3.1-8b-instant

# Server
PORT=3000
